# Provider de tempo real: websocket (padrão) ou firebase
NEXT_PUBLIC_PROVIDER=websocket

# Máximo de participantes por sala ao vivo (padrão 100, máximo 500)
# MAX_ROOM_PARTICIPANTS=100

# OpenRouter (opcional) — geração de perguntas por IA no editor
# OPENROUTER_API_KEY=
# OPENROUTER_MODEL=openai/gpt-4o-mini
# Limite de chamadas /api/quizzes/generate por usuário (Firebase UID), padrão 10
# QUIZ_AI_MAX_GENERATIONS_PER_USER=10

# Firebase (obrigatório quando NEXT_PUBLIC_PROVIDER=firebase)
# Configuração do cliente - obter no Console Firebase > Configurações do projeto
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_DATABASE_URL=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Firebase Admin (servidor) - para API routes no modo Firebase
# Opção 1: Caminho para arquivo JSON da conta de serviço
# GOOGLE_APPLICATION_CREDENTIALS=./firebase-service-account.json
# Opção 2: Variáveis individuais (private key com \n escapado)
# FIREBASE_PROJECT_ID=
# FIREBASE_CLIENT_EMAIL=
# FIREBASE_PRIVATE_KEY=

# Google Analytics (GA4)
# ID de medição do GA4 (ex: G-)
NEXT_PUBLIC_GA_MEASUREMENT_ID=
# Desabilitar GA em desenvolvimento (true | false)
NEXT_PUBLIC_GA_ENABLED=true

# Google AdSense
# ID do publicador (ex: ca-pub-XXXXXXXXXXXXXXXX)
NEXT_PUBLIC_ADSENSE_CLIENT_ID=
# Desabilitar AdSense em desenvolvimento (true | false)
NEXT_PUBLIC_ADSENSE_ENABLED=true
# Slots de anúncio (criar unidades no painel AdSense e preencher)
# NEXT_PUBLIC_ADSENSE_SLOT_BANNER=
# NEXT_PUBLIC_ADSENSE_SLOT_RECTANGLE=
