# Configuração para testes E2E com Firebase Emulator (sala global)
# Copie para .env.test ou defina no ambiente ao rodar os testes
#
# Pré-requisito: npm run emulators:start (em outro terminal)
#
# O projectId deve coincidir com o de .firebaserc (ex: hootkaapp)

NEXT_PUBLIC_PROVIDER=firebase
NEXT_PUBLIC_USE_FIREBASE_EMULATOR=true

NEXT_PUBLIC_FIREBASE_API_KEY=demo-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=localhost
NEXT_PUBLIC_FIREBASE_DATABASE_URL=http://127.0.0.1:9000?ns=hootkaapp
NEXT_PUBLIC_FIREBASE_PROJECT_ID=hootkaapp
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=hootkaapp.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123
NEXT_PUBLIC_FIREBASE_APP_ID=demo-app

FIREBASE_AUTH_EMULATOR_HOST=127.0.0.1:9099
FIREBASE_DATABASE_EMULATOR_HOST=127.0.0.1:9000
