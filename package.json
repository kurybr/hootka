{
  "name": "hootka",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tsx server.ts",
    "build": "next build",
    "build:server": "tsc -p tsconfig.server.json",
    "build:all": "npm run build && npm run build:server",
    "start": "NODE_ENV=production tsx server.ts",
    "lint": "next lint",
    "docker:build": "docker build -t hootka:latest .",
    "docker:run": "docker run --rm -p 3000:3000 hootka:latest",
    "db:clear": "tsx scripts/clear-database.ts --confirm",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install chromium",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:live": "NEXT_PUBLIC_PROVIDER=websocket playwright test --project=live-rooms",
    "test:e2e:live:headed": "NEXT_PUBLIC_PROVIDER=websocket playwright test --project=live-rooms --headed",
    "test:e2e:global": "NEXT_PUBLIC_USE_FIREBASE_EMULATOR=true NEXT_PUBLIC_PROVIDER=firebase NEXT_PUBLIC_FIREBASE_DATABASE_URL=http://127.0.0.1:9000?ns=hootkaapp NEXT_PUBLIC_FIREBASE_PROJECT_ID=hootkaapp FIREBASE_AUTH_EMULATOR_HOST=127.0.0.1:9099 FIREBASE_DATABASE_EMULATOR_HOST=127.0.0.1:9000 playwright test --project=global-room",
    "test:e2e:global:headed": "NEXT_PUBLIC_USE_FIREBASE_EMULATOR=true NEXT_PUBLIC_PROVIDER=firebase NEXT_PUBLIC_FIREBASE_DATABASE_URL=http://127.0.0.1:9000?ns=hootkaapp NEXT_PUBLIC_FIREBASE_PROJECT_ID=hootkaapp FIREBASE_AUTH_EMULATOR_HOST=127.0.0.1:9099 FIREBASE_DATABASE_EMULATOR_HOST=127.0.0.1:9000 playwright test --project=global-room --headed",
    "emulators:start": "npx firebase emulators:start --only auth,database",
    "emulators:seed": "FIREBASE_AUTH_EMULATOR_HOST=127.0.0.1:9099 FIREBASE_DATABASE_EMULATOR_HOST=127.0.0.1:9000 NEXT_PUBLIC_FIREBASE_DATABASE_URL=http://127.0.0.1:9000?ns=hootkaapp NEXT_PUBLIC_FIREBASE_PROJECT_ID=hootkaapp npx tsx scripts/seed-emulator.ts"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.4",
    "@radix-ui/react-separator": "^1.1.0",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-toast": "^1.2.4",
    "canvas-confetti": "^1.9.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "firebase": "^12.9.0",
    "firebase-admin": "^13.6.1",
    "framer-motion": "^12.34.2",
    "lucide-react": "^0.468.0",
    "next": "^15.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "tailwind-merge": "^2.6.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "firebase-tools": "^13.0.0",
    "@eslint/eslintrc": "^3.0.0",
    "@types/canvas-confetti": "^1.9.0",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.1",
    "@types/react-dom": "^19.0.2",
    "dotenv": "^16.6.1",
    "eslint": "^9.17.0",
    "eslint-config-next": "^15.1.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.16",
    "tailwindcss-animate": "^1.0.7",
    "tsx": "^4.21.0",
    "typescript": "^5.7.2"
  }
}
